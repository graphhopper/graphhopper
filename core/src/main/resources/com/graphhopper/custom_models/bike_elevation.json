// consider speed changes due to elevation changes
{
  "speed": [
    { "if":      "average_slope >= 15", "limit_to": "3" },
    { "else_if": "average_slope >= 10", "limit_to": "6" },
    { "else_if": "average_slope >= 6",  "multiply_by": "0.55" },
    { "else_if": "average_slope >= 3",  "multiply_by": "0.75" },
    { "else_if": "average_slope <= -6", "multiply_by": "1.60" },
    { "else_if": "average_slope <= -3", "multiply_by": "1.40" }
  ]
}
