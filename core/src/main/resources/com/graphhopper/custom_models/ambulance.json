// to use this custom model you need to set the following option in the config.yml
// graph.encoded_values: car_access, car_average_speed, max_speed, ferry_speed
// profiles:
//    - name: car_ambulance
//      turn_costs:
//        vehicle_types: [motorcar, emergency]
//      custom_model_files: [ambulance.json]

{
  "distance_influence": 10,
  "priority": [
    { "if": "!car_access || road_environment == FERRY", "multiply_by": "0.001" },
    { "if": "max_weight < 3.5 || max_height < 3", "multiply_by": "0" }
  ],
  "speed": [
    { "if": "road_class_link", "limit_to": 36 },
    { "else_if": "road_class == MOTORWAY", "limit_to": 105 },
    { "else_if": "road_class == TRUNK", "limit_to": 89 },
    { "else_if": "road_class == PRIMARY", "limit_to": 54 },
    { "else_if": "road_class == SECONDARY", "limit_to": 47 },
    { "else_if": "road_class == TERTIARY", "limit_to": 40 },
    { "else_if": "road_class == TRACK", "limit_to": 35 },
    { "else_if": "road_class == UNCLASSIFIED", "limit_to": 29 },
    { "else_if": "road_class == RESIDENTIAL", "limit_to": 17 },
    { "else_if": "road_class == SERVICE || road_class == FOOTWAY || road_class == LIVING_STREET || road_class == PEDESTRIAN", "limit_to": 9 },
    { "else_if": "road_environment == FERRY", "limit_to": "ferry_speed" },
    { "else": "", "limit_to": 29 },
    { "if": "true", "limit_to": "car_average_speed" }
  ]
}
